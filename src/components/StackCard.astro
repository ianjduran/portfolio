---
type Props = {
  text: string
  href?: string
}

const { text, href } = Astro.props
---

{href ? (
<a href={href} target="_blank" rel="noopener noreferrer" aria-label={`${text} (opens in new tab)`} class="font-technical-sm border border-outline-variant text-on-surface-variant px-3 py-1 hover:text-white hover:border-tertiary transition-colors duration-300">
  {text}
</a>
) : (
<span class="font-technical-sm border border-outline-variant text-on-surface-variant px-3 py-1">
  {text}
</span>
)}