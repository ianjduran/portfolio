---
import { SOCIALS } from "@consts"
---

<footer class="w-full border-t border-outline-variant/30 bg-base-bg">
  <div class="flex flex-col md:flex-row justify-between items-center px-12 py-16 gap-8 max-w-[1440px] mx-auto">
    <div class="font-eyebrow-mono text-label-caps uppercase tracking-[0.2em] text-on-surface-variant/60">
      &copy; {new Date().getFullYear()} IAN JAVIER DURAN ROMÁN. ENGINEERED PRECISION.
    </div>
    
    <div class="flex gap-12">
      {SOCIALS.map((social) => (
        <a 
          href={social.HREF} 
          target="_blank" 
          rel="noopener noreferrer"
          aria-label={social.NAME}
          class="font-eyebrow-mono text-label-caps uppercase tracking-[0.2em] text-on-surface-variant hover:text-primary transition-colors"
        >
          {social.NAME}
        </a>
      ))}
    </div>
  </div>
</footer>