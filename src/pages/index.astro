---
import { getCollection } from "astro:content"
import PageLayout from "@layouts/PageLayout.astro"
import ArrowCard from "@components/ArrowCard"
import StackCard from "@components/StackCard.astro"
import { SITE, SOCIALS } from "@consts"

const projects = (await getCollection("projects"))
  .filter(project => !project.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0,3)

const skillCategories = [
  {
    label: "Embedded & Robotics",
    skills: [
      { text: "Embedded C/C++", icon: "", href: "" },
      { text: "ROS/ROS2", icon: "", href: "" },
      { text: "PCB Design", icon: "", href: "" },
      { text: "CAN Protocol", icon: "", href: "" },
      { text: "RTOS", icon: "", href: "" },
      { text: "KiCad", icon: "", href: "" },
      { text: "Sensor Fusion", icon: "", href: "" },
      { text: "Linux", icon: "", href: "" },
    ]
  },
  {
    label: "Cloud & Data",
    skills: [
      { text: "AWS (S3, Lambda, Glue)", icon: "", href: "" },
      { text: "Python", icon: "", href: "" },
      { text: "PostgreSQL", icon: "", href: "" },
      { text: "MySQL", icon: "", href: "" },
      { text: "Terraform", icon: "", href: "" },
      { text: "Power BI", icon: "", href: "" },
    ]
  },
  {
    label: "DevOps & Monitoring",
    skills: [
      { text: "Docker", icon: "", href: "" },
      { text: "Kubernetes", icon: "", href: "" },
      { text: "Prometheus", icon: "", href: "" },
      { text: "Grafana", icon: "", href: "" },
      { text: "OpenSearch", icon: "", href: "" },
      { text: "Git", icon: "", href: "" },
    ]
  },
  {
    label: "Web",
    skills: [
      { text: "Javascript", icon: "javascript", href: "https://www.javascript.com" },
      { text: "Typescript", icon: "typescript", href: "https://www.typescriptlang.org" },
      { text: "Astro", icon: "astro", href: "https://astro.build" },
      { text: "Tailwind CSS", icon: "tailwind", href: "https://tailwindcss.com" },
    ]
  },
]
---

<PageLayout title="Home" description={SITE.DESCRIPTION}>


  
  <!-- HERO -->
  <section class="relative h-screen w-full">
    
    <div class="animate absolute h-full w-full flex items-center">
      <div class='mx-auto md:ml-32 relative w-full h-full flex items-center'>
        <div class='p-5'>
          <p class='animated text-lg md:text-xl lg:text-lg opacity-75 font-display tracking-wide'>
            Hey There! My name is
          </p>
          <p class='animated text-3xl md:text-4xl lg:text-6xl font-bold font-display bg-gradient-to-r from-primary via-blue-400 to-teal-400 bg-clip-text text-transparent pb-2'>
            Ian Javier Duran Román
          </p>
          <p class='animated text-sm md:text-base font-medium lg:text-lg opacity-75 font-display tracking-widest uppercase'>
            Robotics and Digital Systems Engineer
          </p>
          <div id="ctaButtons" class='animated flex flex-wrap gap-4 mt-5'>
            <a href='/projects' class='py-2 px-6 rounded-lg truncate text-xs md:text-sm lg:text-base bg-primary text-white hover:bg-primary/90 hover:shadow-[0_0_15px_rgba(37,123,244,0.4)] transition-all duration-300 font-display tracking-wide'>
              Get my resume!
            </a>
            <a href='/work' class='py-2 px-6 truncate rounded-lg text-xs md:text-sm lg:text-base border border-black/20 dark:border-white/20 hover:border-primary dark:hover:border-primary hover:bg-primary/5 hover:text-primary dark:hover:bg-primary/10 transition-all duration-300 font-display tracking-wide backdrop-blur-sm'>
              View my work
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="relative bg-white dark:bg-black">
    <div class="mx-auto md:ml-32 max-w-screen-sm p-5 space-y-24 pb-16">

      <!-- About Section -->
      <section class="animate">
        <article>
          <p>I am passionate about <b><i>Embedded Systems, Robotics, and Cloud Engineering</i></b> — and equally enthusiastic about design and photography. Also known as a <b><i>builder</i></b>, <b><i>minimalist</i></b>, and <b><i>eternal optimist</i></b>.</p>
          <p>I love to both build and break things. I am motivated by challenging projects with people from different disciplines, and I thrive on dynamic problem solving at the intersection of hardware and software.</p>
          <p>Professionally, I have worked as an <b>AI & Data Engineering Consultant at Deloitte</b>, a <b>DevOps Intern at Sailpoint</b>, and spent two years leading embedded systems development at the <b>VantTec Robotics Research Group</b> at ITESM.</p>
          <p>On my free time I love exploring creative skills, finding balance, and building more integrative solutions.</p>
          <p>Check out my work and projects below!</p>
        </article>
      </section>
    </div>
    <div class="mx-auto max-w-screen-sm p-5 space-y-24 pb-16">
      <!-- Tech Stack Section -->
      <section class="animate">
        <div class="space-y-4">
          <p class="font-semibold text-black dark:text-white">
            My skills
          </p>
          {skillCategories.map(category => (
            <div>
              <p class="text-sm font-medium opacity-60 mb-2 mt-4">
                {category.label}
              </p>
              <div class="flex flex-wrap items-center gap-2">
                {category.skills.map(item => (
                  <StackCard 
                    text={item.text}
                    icon={item.icon}
                    href={item.href}
                  />
                ))}
              </div>
            </div>
          ))}
        </div>
      </section>

      <!-- Project Preview Section -->
      <section class="animate">
        <div class="space-y-4">
          <div class="flex justify-between">
            <p class="font-semibold text-black dark:text-white">
              Recent projects
            </p>
            <a href="/projects" class="w-fit col-span-3 group flex gap-1 items-center underline decoration-[.5px] decoration-black/25 dark:decoration-white/50 hover:decoration-black dark:hover:decoration-white text-black dark:text-white underline-offset-2 blend">
              <span class="text-black/75 dark:text-white/75 group-hover:text-black group-hover:dark:text-white blend">
                All projects
              </span>
            </a>
          </div>
          <ul class="space-y-4">
            {projects.map((project) => (
              <li>
                <ArrowCard entry={project} />
              </li>
            ))}
          </ul>
        </div>
      </section>

      <!-- Contact Section -->
      <section class="animate">
        <div>
          <p class="font-semibold text-black dark:text-white">
            Let's Connect
          </p>
          <p>
            Reach out to me via email or on social media.
          </p>
          <div class="grid grid-cols-4 gap-y-2 mt-4 auto-cols-min">
            {SOCIALS.map(social => (
              <div class="col-span-1 flex items-center gap-1">
                <span class="whitespace-nowrap truncate">
                  {social.NAME}
                </span>
              </div>
              <div class="col-span-3 truncate">
                <a href={social.HREF} target="_blank" class="w-fit col-span-3 group flex gap-1 items-center underline decoration-[.5px] decoration-black/25 dark:decoration-white/50 hover:decoration-black dark:hover:decoration-white text-black dark:text-white underline-offset-2 blend">
                  <span class="text-black/75 dark:text-white/75 group-hover:text-black group-hover:dark:text-white blend">
                    {social.TEXT}
                  </span>
                </a>
              </div>
            ))}
        </div>
      </section>
    </div>
  </div>
</PageLayout>
