---
import { getCollection } from "astro:content"
import PageLayout from "@layouts/PageLayout.astro"
import { WORK } from "@consts"

const collection = await getCollection("work")
collection.sort((a, b) => new Date(b.data.dateStart).getTime() - new Date(a.data.dateStart).getTime())

const work = await Promise.all(
  collection.map(async (item) => {
    const { Content } = await item.render()
    return { ...item, Content }
  })
)

function formatWorkDate(input: Date | string): string {
  if (typeof input === "string") return input

  const month = input.toLocaleDateString("en-US", {
    month: "short",
  })

  const year = new Date(input).getFullYear()
  return `${month} ${year}`
}
---

<PageLayout title={WORK.TITLE} description={WORK.DESCRIPTION}>
  
  <div class="max-w-[1440px] mx-auto px-4 md:px-12 pt-12 md:pt-24 pb-32">
    <!-- Hero Section -->
    <section class="mb-24 relative">
      <div class="absolute -left-6 top-2 text-white/20 hidden md:block" aria-hidden="true">
        <svg fill="none" height="12" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" width="12">
          <path d="M0 0h24v24H0z" stroke="none"></path>
          <path d="M2 12h20M12 2v20"></path>
        </svg>
      </div>
      <p class="animate font-eyebrow-mono text-primary-container uppercase mb-4 tracking-[0.14em]">Professional Tenure</p>
      <h1 class="animate font-display-hero text-5xl text-on-surface leading-[0.9] font-bold" style="--anim-delay: 100ms">Engineering Impact</h1>
    </section>

    <!-- Experience Grid -->
    <div class="flex flex-col gap-12">
      {work.map((entry, index) => {
        const isGlass = index % 2 === 1;

        return (
          <div class={`animate relative p-8 md:p-12 rounded-lg transition-all duration-500 border-[0.5px] border-white/10 hover:border-primary/30 group ${isGlass ? 'bg-white/[0.04] backdrop-blur-md hover:bg-white/[0.06]' : 'bg-card-bg'}`}>
            
            {/* Corner Mark */}
            {!isGlass && (
              <div class="absolute top-0 right-0 w-12 h-12 border-t-[0.5px] border-r-[0.5px] border-primary/40 rounded-tr-lg opacity-50 group-hover:opacity-100 transition-opacity"></div>
            )}
            
            <div class="grid grid-cols-1 md:grid-cols-12 gap-8 md:gap-12">
              <div class="md:col-span-5">
                <span class="font-eyebrow-mono text-primary uppercase mb-2 block tracking-widest">
                  {formatWorkDate(entry.data.dateStart)} — {formatWorkDate(entry.data.dateEnd)} | {entry.data.company}
                </span>
                <h2 class="font-heading-section text-3xl md:text-4xl font-bold text-on-surface mb-4 font-serif">{entry.data.role}</h2>
                
                {/* Abstract Graphical Representation for the role */}
                <div class="w-full aspect-video overflow-hidden bg-base-bg border-[0.5px] border-white/5 relative flex items-center justify-center rounded mt-8">
                  <div class="absolute inset-0 grid-bg-sm"></div>

                  {isGlass ? (
                    <svg aria-hidden="true" class="w-2/3 h-2/3 text-white/20" fill="none" stroke="currentColor" stroke-width="0.5" viewBox="0 0 200 100">
                      <rect height="60" width="80" x="20" y="20"></rect>
                      <rect height="60" width="60" x="120" y="20"></rect>
                      <path d="M100 50 L120 50" stroke-dasharray="4 4"></path>
                    </svg>
                  ) : (
                    <svg aria-hidden="true" class="w-2/3 h-2/3 text-white/20" fill="none" stroke="currentColor" stroke-width="0.5" viewBox="0 0 100 100">
                      <circle cx="50" cy="50" r="30"></circle>
                      <circle cx="50" cy="50" r="20" stroke-dasharray="2 2"></circle>
                      <path d="M50 10 L50 90 M10 50 L90 50"></path>
                    </svg>
                  )}
                  <div class="absolute bottom-2 right-2 font-eyebrow-mono text-[9px] text-primary">SYS_OP_{index + 1}</div>
                </div>
              </div>
              
              <div class="md:col-span-7 flex flex-col justify-between">
                <article class="prose prose-invert prose-p:font-body-main prose-p:text-on-surface-variant prose-li:font-body-main prose-li:text-on-surface-variant prose-li:marker:text-primary marker:text-primary max-w-none">
                  <entry.Content />
                </article>
                
                {/* Optional decorative bottom element */}
                <div class="flex justify-end mt-8 border-t border-white/5 pt-4">
                  <span class="material-symbols-outlined text-white/10 group-hover:text-primary/50 transition-colors">memory</span>
                </div>
              </div>
            </div>
          </div>
        )
      })}
    </div>

  </div>
</PageLayout>
